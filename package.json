{
  "name": "giveaway-bot-max",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.14",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "bun run build:web && bun run build:server",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "lint": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@maxhub/max-bot-api": "^0.2.2",
    "@maxhub/max-ui": "^0.1.13",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
